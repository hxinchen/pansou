# Generate a unique password before deployment. Do not use this placeholder.
POSTGRES_PASSWORD=replace-with-a-random-password
DATABASE_URL=postgres://pansou:replace-with-a-random-password@postgres:5432/pansou?sslmode=disable
# Used only when the users table is empty. Remove ADMIN_PASSWORD after the
# first successful bootstrap if your deployment workflow supports it.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-separate-admin-password
AUTH_JWT_SECRET=replace-with-a-separate-random-signing-secret
# Generate with: openssl rand -base64 32
# Back up this value together with PostgreSQL. Losing it makes saved plugin
# credentials unrecoverable.
PLUGIN_CREDENTIAL_MASTER_KEY=replace-with-base64-encoded-32-random-bytes
DEFAULT_USER_RPS=3
DEFAULT_USER_RPM=60
USAGE_LOG_RETENTION_DAYS=30

# Legacy fallback only: when ADMIN_USERNAME/ADMIN_PASSWORD are absent and the
# users table is empty, the first AUTH_USERS entry is imported as the admin.
# AUTH_USERS=admin:replace-with-a-separate-admin-password
